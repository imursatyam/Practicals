 \par
# Load the spaCy model\par
nlp = spacy.load("en_core_web_sm")\par
 \par
# Sample text corpus\par
text_corpus = """\par
The Eiffel Tower is a wrought-iron lattice tower on the Champ de Mars in Paris, France.\par
It is named after the engineer Gustave Eiffel, whose company designed and built the tower.\par
The tower is 330 meters tall and was completed in 1889.\par
"""\par
 \par
# Process the text with spaCy\par
doc = nlp(text_corpus)\par
 \par
# Extract entities (e.g., names, dates, locations)\par
entities = [(ent.text, ent.label_) for ent in doc.ents]\par
print("Extracted Entities:", entities)\par
from sklearn.feature_extraction.text import TfidfVectorizer\par
from sklearn.metrics.pairwise import cosine_similarity\par
 \par
# Preprocess the text and extract sentences\par
sentences = [sent.text for sent in doc.sents]\par
 \par
# Create a TF-IDF vectorizer\par
vectorizer = TfidfVectorizer()\par
X = vectorizer.fit_transform(sentences)\par
 \par
def answer_question(question):\par
    # Vectorize the question\par
    question_vec = vectorizer.transform([question])\par
   \par
    # Compute cosine similarity between the question and each sentence\par
    similarities = cosine_similarity(question_vec, X)\par
   \par
    # Find the most similar sentence\par
    most_similar_idx = similarities.argmax()\par
    most_similar_sentence = sentences[most_similar_idx]\par
   \par
    return most_similar_sentence\par
 \par
# Example usage\par
question = "How tall is the Eiffel Tower?"\par
answer = answer_question(question)\par
print("Answer:", answer)\par
def enhanced_answer_question(question):\par
    # Vectorize the question\par
    question_vec = vectorizer.transform([question])\par
   \par
    # Compute cosine similarity between the question and each sentence\par
    similarities = cosine_similarity(question_vec, X)\par
   \par
    # Find the most similar sentence\par
    most_similar_idx = similarities.argmax()\par
    most_similar_sentence = sentences[most_similar_idx]\par
   \par
    # Extract entities from the most similar sentence\par
    doc = nlp(most_similar_sentence)\par
    entities = [(ent.text, ent.label_) for ent in doc.ents]\par
   \par
    # Return the sentence and relevant entities\par
    return most_similar_sentence, entities\par
 \par
# Example usage\par
question = "Who designed the Eiffel Tower?"\par
answer, entities = enhanced_answer_question(question)\par
print("Answer:", answer)\par
print("Relevant Entities:", entities)\par
