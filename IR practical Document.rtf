  4: "apple" \par
\} \par
def build_index(docs): \par
  index = \{\} \par
  for doc_id, text in docs.items(): \par
   terms = set(text.split()) \par
   for term in terms: \par
    if term not in index: \par
      index[term] = \{doc_id\} \par
    else: \par
      index[term].add(doc_id)\par
  return index\par
                      \par
inverted_index = build_index(documnets)\par
def boolean_and(operands, index): \par
  if not operands: \par
     return list(range(1, len(documnets) + 1)) \par
  result = index.get(operands[0], set()) \par
  for term in operands[1:]: \par
    result = result.intersection(index.get(term, set())) \par
  return list(result) \par
def boolean_or(operands, index): \par
  result = set() \par
  for term in operands: \par
     result = result.union(index.get(term, set())) \par
  return list(result) \par
def boolean_not(operand, index, total_docs): \par
 operand_set = set(index.get(operand, set())) \par
 all_docs_set = set(range(1, total_docs + 1)) \par
 return list(all_docs_set.difference(operand_set)) \par
